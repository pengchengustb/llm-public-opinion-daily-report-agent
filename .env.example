# Application
APP_NAME="Public Opinion Daily Report Agent"
APP_VERSION="0.1.0"
ENVIRONMENT="local"
LOG_LEVEL="INFO"

# Backend
API_HOST="0.0.0.0"
API_PORT="8000"

# Dashboard
DASHBOARD_PORT="8501"
BACKEND_URL="http://localhost:8000"

# Database: use SQLite locally; Docker Compose can override this to PostgreSQL later.
DATABASE_URL="sqlite:///./opinion_monitor.db"

# LLM configuration placeholder. Real LLM calls are intentionally not implemented in PR #1.
LLM_PROVIDER="mock"
LLM_MODEL="mock-structured-analyzer-v1"
OPENAI_API_KEY=""
