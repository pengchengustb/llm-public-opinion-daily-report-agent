# Application
APP_NAME="LLM-enhanced Public Opinion Monitoring"
APP_ENV=local
LOG_LEVEL=INFO

# Backend
API_HOST=0.0.0.0
API_PORT=8000
BACKEND_CORS_ORIGINS=["http://localhost:8501"]

# Database
DATABASE_URL=sqlite:///./data/generated/opinion_monitor.db

# Dashboard
DASHBOARD_BACKEND_URL=http://localhost:8000

# LLM
LLM_PROVIDER=openai
LLM_MODEL=gpt-4.1-mini
LLM_MOCK_MODE=true
OPENAI_API_KEY=

# Reports
REPORT_LANGUAGE=zh-CN
REPORT_OUTPUT_DIR=reports

